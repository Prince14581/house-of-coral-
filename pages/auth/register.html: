<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register | House-of-Coral</title>
    
    <!-- SEO & Security Hardening -->
    <meta name="description" content="Create your secure House-of-Coral account.">
    <meta name="robots" content="noindex,nofollow">
    <meta name="google" content="notranslate">
    <meta name="theme-color" content="#0d1117">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self';">
    
    <!-- PWA & Assets -->
    <link rel="icon" href="../../favicon.ico">
    <link rel="manifest" href="../../manifest.json">
    <link rel="stylesheet" href="../../css/main.css">
    <link rel="stylesheet" href="auth.css">
</head>
<body class="auth-layout">

    <noscript>
        <p class="noscript-warning">JavaScript is required to register for House-of-Coral.</p>
    </noscript>

    <div id="loadingOverlay" hidden role="status" aria-live="polite" aria-atomic="true">
        <div class="loading-spinner"></div>
        <p>Creating your account...</p>
    </div>

    <main id="registerPage" class="auth-container">
        <header>
            <img src="../../assets/logos/logo.svg" alt="House-of-Coral Logo" class="auth-logo">
            <h1>Join House-of-Coral</h1>
            <p>Start your journey with our unified platform</p>
        </header>

        <div id="authMessage" role="alert" aria-live="polite" aria-atomic="true"></div>

        <form id="registerForm" novalidate>
            <input type="hidden" name="_csrf" id="csrfToken">

            <div class="form-group">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" name="fullName" required autocomplete="name" 
                       maxlength="100" aria-required="true" aria-describedby="authMessage">
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required autocomplete="username" 
                       spellcheck="false" maxlength="254" aria-required="true" 
                       aria-describedby="authMessage">
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="password-wrapper">
                    <input type="password" id="password" name="password" required 
                           autocomplete="new-password" spellcheck="false" maxlength="128" 
                           aria-required="true" aria-describedby="authMessage">
                    <button type="button" id="togglePassword" aria-label="Show password" 
                            aria-pressed="false" aria-controls="password">👁</button>
                </div>
                <p class="password-hint">Minimum 8 characters with uppercase, lowercase, number, and symbol.</p>
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <div class="password-wrapper">
                    <input type="password" id="confirmPassword" name="confirmPassword" required 
                           autocomplete="new-password" spellcheck="false" maxlength="128" 
                           aria-required="true" aria-describedby="authMessage">
                    <button type="button" id="toggleConfirmPassword" aria-label="Show password" 
                            aria-pressed="false" aria-controls="confirmPassword">👁</button>
                </div>
            </div>

            <div id="socialLogin"></div>

            <div class="form-group checkbox">
                <label>
                    <input type="checkbox" id="termsAccepted" name="termsAccepted" required>
                    I agree to the <a href="../legal/terms.html">Terms of Service</a> and <a href="../legal/privacy.html">Privacy Policy</a>.
                </label>
            </div>

            <div class="form-group checkbox">
                <label>
                    <input type="checkbox" id="newsletter" name="newsletter">
                    Receive House-of-Coral updates.
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" id="submitBtn">
                    <span class="btn-text">Create Account</span>
                    <span class="spinner" hidden></span>
                </button>
            </div>
        </form>

        <footer class="auth-footer">
            <p>Already have an account? <a href="login.html">Sign in</a></p>
            <nav aria-label="Authentication links">
                <a href="../legal/terms.html">Terms</a> | 
                <a href="../legal/privacy.html">Privacy</a> | 
                <a href="../support/support.html">Support</a> | 
                <a href="../support/status.html">Status</a>
            </nav>
            <p class="copyright">&copy; 2026 House-of-Coral</p>
        </footer>
    </main>

    <script src="../../js/auth.js" defer></script>
</body>
</html>
