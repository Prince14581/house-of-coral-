{
  "name": "House-of-Coral",
  "short_name": "HoC",
  "description": "Unified ecosystem of eight digital pillars including Marketplace, Real Estate, Gaming, and Live Streaming.",
  "lang": "en",
  "dir": "ltr",
  "start_url": "/",
  "id": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "background_color": "#0d1117",
  "theme_color": "#0d1117",
  "orientation": "portrait",
  "handle_links": "preferred",
  "edge_side_panel": { "preferred_width": 420 },
  "launch_handler": { "client_mode": "focus-existing" },
  "url_handlers": [{ "origin": "https://houseofcoral.com" }],
  "scope_extensions": [{ "origin": "https://houseofcoral.com" }],
  "protocol_handlers": [{ "protocol": "web+hoc", "url": "/?url=%s" }],
  "file_handlers": [
    {
      "action": "/open",
      "accept": {
        "image/*": [".png", ".jpg", ".jpeg"],
        "video/*": [".mp4"],
        "application/pdf": [".pdf"]
      }
    }
  ],
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": { "title": "title", "text": "text", "url": "url" }
  },
  "icons": [
    { "src": "/assets/icons/favicon-16.png", "sizes": "16x16", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/favicon-32.png", "sizes": "32x32", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-48.png", "sizes": "48x48", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "/assets/icons/icon-256.png", "sizes": "256x256", "type": "image/png", "purpose": "any" },
    { "src": "/assets/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" },
    { "src": "/assets/icons/icon-1024.png", "sizes": "1024x1024", "type": "image/png", "purpose": "any maskable" },
    { "src": "/assets/icons/icon-monochrome.png", "sizes": "512x512", "type": "image/png", "purpose": "monochrome" }
  ],
  "shortcuts": [
    { "name": "Bazaar", "short_name": "Bazaar", "description": "Marketplace for all transactions.", "url": "/bazaar", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Arena", "short_name": "Arena", "description": "Gaming and competitive events.", "url": "/arena", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Stage", "short_name": "Stage", "description": "Live streaming entertainment.", "url": "/stage", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Global Link", "short_name": "Social", "description": "Community connection hub.", "url": "/global-link", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Academy", "short_name": "Academy", "description": "Learn and develop skills.", "url": "/academy", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Treasury", "short_name": "Treasury", "description": "Secure financial management.", "url": "/treasury", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Real Estate", "short_name": "Property", "description": "Digital property investment.", "url": "/real-estate", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] },
    { "name": "Profile", "short_name": "Profile", "description": "Manage your identity.", "url": "/profile", "lang": "en", "icons": [{ "src": "/assets/icons/icon-192.png", "sizes": "192x192", "type": "image/png" }] }
  ],
  "screenshots": [
    { "src": "/assets/images/ss-home.png", "sizes": "1280x720", "type": "image/png", "label": "Dashboard", "description": "Unified platform home view.", "form_factor": "wide" },
    { "src": "/assets/images/ss-bazaar.png", "sizes": "1280x720", "type": "image/png", "label": "Bazaar", "description": "Marketplace for all transactions.", "form_factor": "wide" },
    { "src": "/assets/images/ss-arena.png", "sizes": "1280x720", "type": "image/png", "label": "Arena", "description": "Gaming and events hub.", "form_factor": "wide" },
    { "src": "/assets/images/ss-stage.png", "sizes": "1280x720", "type": "image/png", "label": "Stage", "description": "Live streaming center.", "form_factor": "wide" },
    { "src": "/assets/images/mobile-home.png", "sizes": "720x1280", "type": "image/png", "label": "Dashboard Mobile", "description": "Mobile home view.", "form_factor": "narrow" },
    { "src": "/assets/images/mobile-bazaar.png", "sizes": "720x1280", "type": "image/png", "label": "Bazaar Mobile", "description": "Mobile marketplace view.", "form_factor": "narrow" }
  ],
  "categories": ["shopping", "business", "finance", "education", "social", "entertainment", "productivity", "lifestyle", "communication"],
  "prefer_related_applications": false,
  "related_applications": []
